{
  "expo": {
    "name": "SJC 2001",
    "slug": "sjc2001-mobile",
    "version": "1.0.3",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "sjc2001",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.utsav.sjc2001",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "SJC 2001 needs access to your photo library so you can choose photos for your member profile (school, current, and family photos), upload trip albums and expense receipts, and attach files to committee documents. Photos you select are uploaded only when you tap Save or Submit.",
        "NSPhotoLibraryAddUsageDescription": "SJC 2001 may save photos you share back to your library when you use the Share or Save action.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.utsav.sjc2001",
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ],
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock Silver Circle quickly and securely."
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "usrivastava0920s-organization",
    "extra": {
      "router": {},
      "apiBaseUrl": "https://www.sjcbatch2001.com/api/v1",
      "apiContentBaseUrl": "https://www.sjcbatch2001.com/api",
      "eas": {
        "projectId": "c6428a1d-216a-43e4-a874-7c5028edb863"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c6428a1d-216a-43e4-a874-7c5028edb863"
    }
  }
}
