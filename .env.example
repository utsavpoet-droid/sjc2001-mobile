# Mobile auth + push (versionless paths joined to this base; must end with /api/v1)
EXPO_PUBLIC_API_BASE_URL=https://your-host.example/api/v1

# Optional: content routes base (must end with /api). If omitted, derived from EXPO_PUBLIC_API_BASE_URL.
# EXPO_PUBLIC_API_CONTENT_BASE_URL=https://your-host.example/api
